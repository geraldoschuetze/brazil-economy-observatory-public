# OpenMetadata env — copy to `openmetadata.env` (gitignored) per environment.
# Used as the --env-file when bringing up infra/openmetadata/docker-compose.openmetadata.yml.
# Only the per-environment WIRING and a couple of overrides live here; the
# internal OM DB credentials are baked into the openmetadata/postgresql image
# (no host port exposed) and default correctly in the compose.

# Pin the OpenMetadata release (align with its official reference compose).
OPENMETADATA_VERSION=1.12.11

# --- per-environment wiring (THIS is what changes between dev/qa/prod) ---
# Give the OM stack its OWN compose project (must NOT equal the main stack's),
# and point it at the main stack's external network so ingestion can reach the
# warehouse `postgres` and `superset` hosts.
#   PROD : COMPOSE_PROJECT_NAME=brfin-observatory-om     OM_WAREHOUSE_NETWORK=brfin-observatory_default
#   QA   : COMPOSE_PROJECT_NAME=brfin-observatory-qa-om  OM_WAREHOUSE_NETWORK=brfin-observatory-qa_default
#   DEV  : COMPOSE_PROJECT_NAME=brazil-economy-observatory-om
#          OM_WAREHOUSE_NETWORK=brazil-economy-observatory_default
COMPOSE_PROJECT_NAME=brfin-observatory-om
OM_WAREHOUSE_NETWORK=brfin-observatory_default

# --- public surface topology (CRITICAL — read this) ---
# The full read/write OM server is published ONLY on loopback via OM_PORT (admin
# over SSH tunnel). The PUBLIC catalog is served by the read-only nginx proxy on
# OM_PUBLIC_PORT, which is the port the Cloudflare Tunnel routes the catalog
# hostname to (see infra/cloudflared/config.yml: PROD->8585, QA->8586).
#
# RULE: OM_PUBLIC_PORT must equal the tunnel target; OM_PORT must be a DIFFERENT
# loopback port so the tunnel can never hit the full server. Wrong values silently
# expose the mutable API to the internet.
#   PROD : OM_PORT=8597  OM_PUBLIC_PORT=8585
#   QA   : OM_PORT=8596  OM_PUBLIC_PORT=8586
OM_PORT=8597
OM_PUBLIC_PORT=8585
# Loopback by default; the host-networked cloudflared reaches 127.0.0.1 fine.
# Only set 0.0.0.0 if you must publish the proxy on the LAN (then add a firewall).
OM_PUBLIC_BIND=127.0.0.1

# JVM/ES heap — keep small on the free-tier VM (QA can go lower, e.g. 512m).
OM_HEAP_OPTS=-Xmx1G -Xms1G
OM_ES_JAVA_OPTS=-Xms1024m -Xmx1024m

# JWT signing keys: generate per-environment on the VM with
#   bash scripts/om_gen_jwt_keys.sh
# (writes gitignored infra/openmetadata/certs/{private,public}_key.der, mounted
# into the server). Set a FRESH unique key id below — any UUID works.
JWT_KEY_ID=replace-with-a-fresh-uuid

# Caminho ABSOLUTO do dbt/target na VM (bind-montado read-only no om-ingestion
# para o conector dbt ler manifest/catalog/run_results). É <repo>/dbt/target —
# ex.: /home/ubuntu/brazil-economy-observatory-qa/dbt/target (QA),
#      /home/ubuntu/brazil-economy-observatory/dbt/target (PROD).
OM_DBT_TARGET_HOST=/home/ubuntu/brazil-economy-observatory/dbt/target

# --- secrets: SET THESE per environment (do NOT leave at the image defaults) ---
# The compose still has dev defaults so it boots, but in QA/PROD you MUST override
# them. The Fernet key encrypts OM's stored connection secrets — generate a UNIQUE
# one per environment and rotate the committed dev default:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# OM_FERNET_KEY=<unique-per-env>
# OM_DB_PASSWORD=<random>
# OM_AIRFLOW_DB_PASSWORD=<random>
# OM_POSTGRES_SUPER_PASSWORD=<random>
# OM_AIRFLOW_PASSWORD=<random>

# --- hardening (REQUIRED to activate the read-only viewer + rotate admin) ---
# When OM_ADMIN_NEW_PASSWORD is set, the deploy runs scripts/om_harden.py to
# rotate the factory admin/admin and provision the least-privilege public viewer.
# Without these the stack keeps the well-known admin/admin on the loopback port.
#   openssl rand -hex 24   # for each
# OM_ADMIN_NEW_PASSWORD=<strong>
# OM_VIEWER_PASSWORD=<strong>     # shared read-only UI login
# OM_READER_PASSWORD=<strong>     # least-privilege warehouse reader
