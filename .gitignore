# secrets — never commit
.env
infra/openmetadata/openmetadata.env

# Cloudflare Tunnel credentials (VM-only; config.yml is safe to commit)
infra/cloudflared/creds/

# OpenMetadata JWT signing keys (VM-only, generated by scripts/om_gen_jwt_keys.sh)
infra/openmetadata/certs/*.der

# Airflow runtime
logs/
config/airflow.cfg
plugins/__pycache__/

# dbt build artifacts (compiled SQL, manifest/catalog, run logs)
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# local data is never versioned (lives in Postgres); small samples are ok
data/*
!data/sample/

# Superset runtime
superset_home/

# internal planning notes (not part of the portfolio)
docs/superpowers/

# Claude Code & Spec Kit agent-local files — regenerable via `specify init`,
# not needed in the repo. The spec-kit PROJECT infra in .specify/ IS versioned
# (constitution, templates, workflows).
.claude/
CLAUDE.md
