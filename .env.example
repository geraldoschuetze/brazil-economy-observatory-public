# Template for .env — run `make env` to generate .env with random secrets.
# .env is gitignored and must NEVER be committed.

AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.2
SUPERSET_IMAGE_TAG=6.1.0

# Host ports — override to run a second environment (e.g. QA) on the same box:
# AIRFLOW_PORT=8081, SUPERSET_PORT=8089, POSTGRES_HOST_PORT=5441
AIRFLOW_PORT=8080
SUPERSET_PORT=8088
POSTGRES_HOST_PORT=5440

# --- Airflow ---
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=__GENERATE__
AIRFLOW__API_AUTH__JWT_SECRET=__GENERATE__
FERNET_KEY=__FERNET__

# --- PostgreSQL (one instance, three databases/users) ---
POSTGRES_SUPER_PASSWORD=__GENERATE__
AIRFLOW_DB_PASSWORD=__GENERATE__
SUPERSET_DB_PASSWORD=__GENERATE__
BRAZIL_ECONOMY_DB_PASSWORD=__GENERATE__
# Least-privilege read-only warehouse role for Superset dashboards (security
# finding H3). When set, the deploy provisions the `superset_reader` Postgres
# role and Superset connects with it instead of the warehouse owner.
SUPERSET_READER_PASSWORD=__GENERATE__

# --- Superset ---
SUPERSET_SECRET_KEY=__GENERATE__
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=__GENERATE__
